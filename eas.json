{
  "cli": {
    "version": ">= 20.3.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "packageManager": "pnpm",
      "prebuildCommand": "pnpm --filter @filmsnaps/shared build"
    },
    "preview": {
      "distribution": "internal",
      "packageManager": "pnpm",
      "prebuildCommand": "pnpm --filter @filmsnaps/shared build",
      "channel": "preview"
    },
    "production": {
      "autoIncrement": true,
      "packageManager": "pnpm",
      "prebuildCommand": "pnpm --filter @filmsnaps/shared build"
    }
  },
  "submit": {
    "production": {}
  }
}
